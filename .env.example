# LLM Backend Configuration
# Options: litellm (default), anthropic, google
LLM_BACKEND=litellm

# Model to use (depends on backend)
# litellm: gpt-4o, claude-sonnet-4-20250514, gemini/gemini-2.0-flash, etc.
# anthropic: claude-sonnet-4-20250514, claude-haiku-4-5-20251001
# google: gemini-2.0-flash, gemini-1.5-pro
LLM_MODEL=gpt-4o

# API Keys (set the one matching your backend)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Server
PORT=9002
