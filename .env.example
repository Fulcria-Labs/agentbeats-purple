# LLM Configuration (via litellm - supports 100+ providers)
# See https://docs.litellm.ai/docs/providers for full list

# Model to use (litellm format)
# OpenAI:    gpt-4o, gpt-4o-mini, gpt-4.1
# Anthropic: claude-sonnet-4-20250514, claude-haiku-4-5-20251001
# Google:    gemini/gemini-2.5-flash, gemini/gemini-2.0-flash
# Groq:      groq/llama-3.3-70b-versatile, groq/mixtral-8x7b-32768
# DeepSeek:  deepseek/deepseek-chat
# Cerebras:  cerebras/llama3.3-70b
# Ollama:    ollama/llama3.2, ollama/mistral
LLM_MODEL=gpt-4o

# API Keys (set the one matching your model provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
CEREBRAS_API_KEY=

# Optional: Custom API base (for Ollama, vLLM, etc.)
# LLM_API_BASE=http://localhost:11434

# Agent settings
LLM_TEMPERATURE=0.0
MAX_TOOL_STEPS=15

# Server
PORT=9002
